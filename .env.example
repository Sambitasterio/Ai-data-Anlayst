OPENAI_API_KEY=sk-...
GEMINI_API_KEY=
GROQ_API_KEY=

# Backend JWT + optional GitHub oauth sync (same secret in frontend AUTH_SYNC_SECRET)
JWT_SECRET=change-me-in-production
AUTH_SYNC_SECRET=

# Comma-separated browser origins allowed for CORS (default * if unset locally)
CORS_ORIGINS=http://localhost:3000

# Override SQLite DB (Docker compose uses sqlite:////data/app.db)
# DATABASE_URL=sqlite:///./backend/app.db

# Seed demo_orders CSV on startup when DuckDB registry is empty (1/true/yes)
AUTOLOAD_DEMO_SAMPLE=0

PORT=8000

# NextAuth lives in frontend/.env.local — see README
